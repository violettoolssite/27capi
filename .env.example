# ============================================================
# 27c API 环境变量配置
# 使用说明：将此文件复制为 .env.local，按需填写后重启服务
# .env.local 已加入 .gitignore，不会被提交到版本控制
# 所有变量均可选；若不填，系统使用 data/config.json 中的值
# ============================================================


# -----------------------------------------------------------
# [安全] JWT 签名密钥（强烈建议在生产环境设置）
# 生成方法：node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# -----------------------------------------------------------
JWT_SECRET=


# -----------------------------------------------------------
# [权限] 管理员密码直接覆盖（优先级高于 config.json）
# 设置后，/admin 和 /zidingyi 的登录密码以此为准
# -----------------------------------------------------------
ADMIN_PASSWORD_OVERRIDE=


# -----------------------------------------------------------
# [上游] API 接口覆盖（优先级高于 config.json）
# 设置后，管理面板中的上游配置将被此覆盖（只读展示）
# -----------------------------------------------------------
UPSTREAM_BASE_URL=
UPSTREAM_API_KEY=
UPSTREAM_TIMEOUT_MS=60000


# -----------------------------------------------------------
# [邮件] SMTP 发信配置（优先级高于 config.json）
# 支持：Gmail、QQ邮箱、企业邮箱、Resend、SendGrid 等
# Gmail 示例：SMTP_HOST=smtp.gmail.com  SMTP_PORT=587
# QQ邮箱示例：SMTP_HOST=smtp.qq.com    SMTP_PORT=465
# -----------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM_NAME=
SMTP_FROM_EMAIL=


# -----------------------------------------------------------
# [数据] 数据目录（默认 ./data）
# -----------------------------------------------------------
DATA_DIR=


# -----------------------------------------------------------
# [运行] 服务端口（默认 3000）
# -----------------------------------------------------------
PORT=3000


# -----------------------------------------------------------
# [环境] 运行环境（development / production）
# -----------------------------------------------------------
NODE_ENV=production
